{
  "name": "bridgefy-react-native-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "react-native build-ios --mode Debug",
    "clean:build": " rm -Rf build node_modules vendor Gemfile.lock android/build android/.gradle android/build android/.kotlin android/.idea android/app/.cxx android/app/build ios/build ios/**.xcworkspace ios/Podfile.lock ios/Pods"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.83.6",
    "@react-navigation/bottom-tabs": "^7.6.0",
